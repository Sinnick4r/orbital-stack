# orbital-stack — local development environment.
# Copy to .env and fill in. .env is gitignored.
# Same variables are required as GitHub Actions secrets for CI.

# Space-Track credentials — https://www.space-track.org/
SPACETRACK_USER=
SPACETRACK_PASSWORD=

# Backblaze B2 — DVC remote storage
DVC_B2_KEY_ID=
DVC_B2_APP_KEY=

# Optional logging overrides
# ORBITAL_LOG_FORMAT=console
# ORBITAL_LOG_LEVEL=DEBUG
